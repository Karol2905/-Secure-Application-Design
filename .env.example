# =============================================================
#  .env.example — Plantilla de variables de entorno
#  Copia este archivo como .env y completa los valores reales.
#  El archivo .env NUNCA se sube al repositorio (.gitignore).
# =============================================================

# ── Base de datos ─────────────────────────────────────────────
DB_NAME=workshopdb
DB_USER=workshopuser
DB_PASSWORD=CAMBIA_ESTO_por_una_password_segura

# ── JWT ───────────────────────────────────────────────────────
# Mínimo 64 caracteres aleatorios. Genera uno con:
#   openssl rand -hex 64
JWT_SECRET=CAMBIA_ESTO_por_una_cadena_aleatoria_de_minimo_64_caracteres_para_produccion
JWT_EXPIRATION_MS=86400000

# ── CORS ──────────────────────────────────────────────────────
# En producción: el dominio exacto de tu EC2 con DuckDNS
# En local:      http://localhost
CORS_ALLOWED_ORIGINS=https://TU_DOMINIO.duckdns.org
